# ── PRODUCTION ENVIRONMENT VARIABLES (set these on Railway) ──────────────────

NODE_ENV=production
PORT=4000

# PostgreSQL from Railway (Railway auto-sets DATABASE_URL when you add a DB)
DATABASE_URL=postgresql://user:password@host:5432/railway

# JWT Secrets — generate strong random strings (32+ chars each)
JWT_SECRET=replace_with_strong_random_secret_min_32_chars
JWT_REFRESH_SECRET=replace_with_another_strong_random_secret_min_32_chars
JWT_EXPIRES_IN=4h
JWT_REFRESH_EXPIRES_IN=30d

# Your Vercel frontend URL (update with your actual Vercel URL)
FRONTEND_URL=https://philix-finance.vercel.app

# Email (optional — leave blank to disable welcome emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="Philix Finance <noreply@philixfinance.com>"

# Company Info
COMPANY_NAME="Philix Finance"
COMPANY_SLOGAN="Creating a Future Together"
COMPANY_PHONE="+260 XXX XXXXXX"
COMPANY_EMAIL=info@philixfinance.com
COMPANY_ADDRESS="Lusaka, Zambia"
MFA_ISSUER="Philix Finance"
