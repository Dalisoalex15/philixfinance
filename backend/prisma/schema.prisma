// Philix Finance - SQLite-compatible Schema (minimal for real-app operation)
// Enums replaced with String, JSON replaced with String

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// STAFF AUTH
// ============================================================

model User {
  id               String     @id @default(uuid())
  employeeId       String     @unique
  firstName        String
  lastName         String
  email            String     @unique
  phone            String
  passwordHash     String
  role             String     @default("LOAN_OFFICER")
  // SUPER_ADMIN | MANAGER | LOAN_OFFICER | COLLECTIONS_OFFICER | ACCOUNTANT
  status           String     @default("ACTIVE")
  // ACTIVE | SUSPENDED | INACTIVE
  branchId         String?
  avatarUrl        String?
  mfaEnabled       Boolean    @default(false)
  mfaSecret        String?
  lastLoginAt      DateTime?
  lastLoginIp      String?
  failedLoginCount Int        @default(0)
  lockedUntil      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  refreshTokens    RefreshToken[]
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  ipAddress String?
  userAgent String?
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  action      String
  entity      String
  entityId    String?
  oldValue    String?
  newValue    String?
  description String
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
}

// ============================================================
// CLIENT PORTAL
// ============================================================

model ClientPortalAccount {
  id                String   @id @default(uuid())
  clientNumber      String   @unique
  email             String   @unique
  passwordHash      String
  firstName         String
  lastName          String
  phone             String
  dateOfBirth       DateTime?
  gender            String?
  address           String?
  city              String?
  occupation        String?
  employer          String?
  monthlyIncome     Float?
  nrcNumber         String?
  kycStatus         String   @default("NOT_STARTED")
  // NOT_STARTED | SUBMITTED | IN_REVIEW | VERIFIED | REJECTED
  kycSubmittedAt    DateTime?
  kycVerifiedAt     DateTime?
  kycRejectedReason String?
  status            String   @default("PENDING_KYC")
  // ACTIVE | PENDING_KYC | SUSPENDED | BLACKLISTED
  linkedClientId    String?  @unique
  failedLoginCount  Int      @default(0)
  lockedUntil       DateTime?
  lastLoginAt       DateTime?
  emailVerified     Boolean  @default(false)
  referredByCode    String?  // referral code this account used at registration
  referralCode      String?  @unique // this client's own shareable code
  referralCount     Int      @default(0)
  lastLoginIp       String?
  isTrustedClient   Boolean  @default(false)
  trustScore        Int?      // 0-100 computed trust score
  trustGrantedAt    DateTime?
  trustGrantedBy    String?
  creditScore       Int?      // 0-100 repayment-based credit score
  creditScoreUpdatedAt DateTime?
  isBlacklisted     Boolean  @default(false)
  blacklistReason   String?
  blacklistedAt     DateTime?
  blacklistedBy     String?
  nextOfKinName     String?
  nextOfKinPhone    String?
  nextOfKinRelation String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  portalLoans         PortalLoanApplication[]
  portalRefreshTokens PortalRefreshToken[]
  notifications       ClientNotification[]
  kycDocuments        KycDocument[]
  investments         ClientInvestment[]

  @@index([email])
  @@index([clientNumber])
}

model PortalRefreshToken {
  id          String              @id @default(uuid())
  token       String              @unique
  accountId   String
  account     ClientPortalAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime            @default(now())
}

model PortalLoanApplication {
  id              String              @id @default(uuid())
  reference       String              @unique
  accountId       String
  account         ClientPortalAccount @relation(fields: [accountId], references: [id])
  productType     String
  amountRequested Float
  termMonths      Int
  interestRate    Float    @default(0)
  purpose         String
  description     String?
  occupation      String?
  employer        String?
  employerPhone   String?
  monthlyIncome   Float?
  payDate         String?
  collateralType   String?
  collateralDesc   String?
  collateralValue  Float?
  collateralPhotos String?
  ref1Name        String?
  ref1Phone       String?
  ref1Relation    String?
  ref2Name        String?
  ref2Phone       String?
  ref2Relation    String?

  // Extended borrower info
  nrcNumber            String?
  physicalAddress      String?
  employmentType       String?   // PERMANENT|CONTRACT|CASUAL|SELF_EMPLOYED|STUDENT|UNEMPLOYED
  payrollNumber        String?
  department           String?
  yearsInService       String?
  netSalaryAvailable   Float?
  existingLoanDeductions Float?

  // Enhanced collateral
  collateralCondition  String?   // excellent|good|fair|poor
  collateralYear       String?   // year purchased e.g. "2021"
  collateralSerial     String?   // serial/registration number
  collateralOwner      String?   // "SELF" or owner name if third party
  hasOwnershipDocs     Boolean   @default(false)
  hasInsurance         Boolean   @default(false)
  collateralConditionScore Int?  // 1-5 numeric

  // Guarantor
  guarantorName        String?
  guarantorPhone       String?
  guarantorEmployer    String?
  guarantorRelation    String?

  // Student-specific
  studentInstitution   String?
  studentSponsor       String?
  studentGradYear      String?

  // Auto-computed risk assessment (set at submission time)
  riskScore            Float?    // 0-100 overall score
  riskCategory         String?   // EXCELLENT|GOOD|MODERATE|REJECT
  coverageRatio        Float?    // forcedSaleValue / loanAmount
  marketValue          Float?    // computed market value
  forcedSaleValue      Float?    // liquidation value
  lendingValue         Float?    // max we can lend against this collateral
  maxRecommendedLoan   Float?    // min(lendingValue, incomeBased)
  repossessionScore    String?   // GREEN|AMBER|RED
  assessmentJson       String?   // JSON blob with full breakdown

  status          String   @default("SUBMITTED")
  // SUBMITTED | UNDER_REVIEW | APPROVED | REJECTED | DISBURSED
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectedReason  String?
  linkedLoanId    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  paymentSubmissions LoanPaymentSubmission[]
}

model ClientNotification {
  id           String              @id @default(uuid())
  accountId    String
  account      ClientPortalAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  subject      String
  body         String
  category     String
  isRead       Boolean  @default(false)
  sentViaEmail Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model KycDocument {
  id         String              @id @default(uuid())
  accountId  String
  account    ClientPortalAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  docType    String
  // NRC_FRONT | NRC_BACK | SELFIE | PROOF_OF_ADDRESS | PAYSLIP | OTHER
  fileUrl    String
  fileName   String
  mimeType   String   @default("image/jpeg")
  uploadedAt DateTime @default(now())
}


// ============================================================
// LOAN OFFICER TARGETS
// ============================================================

model LoanOfficerTarget {
  id                  String   @id @default(uuid())
  userId              String
  month               String   // YYYY-MM format
  disbursementTarget  Float    @default(0)
  collectionTarget    Float    @default(0)
  loansTarget         Int      @default(0)
  setBy               String
  setAt               DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([userId, month])
}

// ============================================================
// CAPITAL & FUNDING
// ============================================================

model CapitalEntry {
  id          String   @id @default(uuid())
  type        String   // DEPOSIT | WITHDRAWAL
  amount      Float
  source      String   // MOBILE_MONEY | BANK_TRANSFER | CASH | INVESTOR | OTHER
  provider    String?  // e.g. "Airtel Money", "Zanaco", "FNB"
  reference   String?
  description String?
  addedBy     String
  entryDate   DateTime @default(now())
  createdAt   DateTime @default(now())
}

model LoanPaymentSubmission {
  id             String   @id @default(uuid())
  applicationId  String
  application    PortalLoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  accountId      String
  amount         Float?
  paymentMethod  String?
  provider       String?
  reference      String?
  screenshotData String?
  notes          String?
  status         String   @default("PENDING")
  reviewedBy     String?
  reviewedAt     DateTime?
  rejectedReason String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ============================================================
// EMAIL SYSTEM
// ============================================================

model EmailLog {
  id          String    @id @default(uuid())
  to          String
  toName      String?
  subject     String
  template    String?
  body        String?
  status      String    @default("SENT")
  resendId    String?
  clientId    String?
  loanId      String?
  accountId   String?
  triggeredBy String?
  error       String?
  openedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model OtpVerification {
  id        String   @id @default(uuid())
  email     String
  otp       String
  type      String
  accountId String?
  attempts  Int      @default(0)
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model EmailTemplate {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  subject   String
  htmlBody  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailCampaign {
  id          String    @id @default(uuid())
  name        String
  subject     String
  htmlBody    String
  targetGroup String
  status      String    @default("DRAFT")
  sentAt      DateTime?
  totalSent   Int       @default(0)
  totalFailed Int       @default(0)
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ── CLIENT INVESTMENTS ────────────────────────────────────────────────────────

model InvestmentProduct {
  id            String   @id @default(uuid())
  name          String
  description   String?
  type          String   // FIXED_DEPOSIT | SAVINGS | MONEY_MARKET | NOTICE
  interestRate  Float    // Annual rate (%)
  minAmount     Float    @default(500)
  maxAmount     Float?
  termMonths    Int      // Minimum lock-in period
  isActive      Boolean  @default(true)
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  investments   ClientInvestment[]
}

model ClientInvestment {
  id             String              @id @default(uuid())
  reference      String              @unique
  accountId      String
  account        ClientPortalAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  productId      String
  product        InvestmentProduct   @relation(fields: [productId], references: [id])
  amountInvested Float
  interestRate   Float               // Rate locked at time of investment
  termMonths     Int
  startDate      DateTime            @default(now())
  maturityDate   DateTime
  status         String              @default("PENDING")
  // PENDING | ACTIVE | MATURED | WITHDRAWN | CANCELLED
  expectedReturn Float               // Total expected at maturity
  actualReturn   Float?
  paymentMethod  String?             // CASH | MOBILE_MONEY | BANK_TRANSFER
  paymentRef     String?
  notes          String?
  approvedBy     String?
  approvedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([accountId])
  @@index([status])
}
